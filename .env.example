# Supabase — create project at https://supabase.com then copy from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Books (optional, no key required for basic queries)
# GOOGLE_BOOKS_API_KEY=

# eBay (optional — app runs in simulation mode without these)
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
